{
  "name": "game-design-tools",
  "private": true,
  "version": "0.4.38",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "build": "tsc -b && vite build",
    "desktop:dev": "npm run build && electron .",
    "desktop:build:win": "npm run build && electron-builder --win --x64",
    "test": "tsx --test src/appStructure.test.ts src/desktopBinaryData.test.ts src/components/ProjectStorage/projectActiveProject.test.ts src/components/ProjectStorage/projectStorageModel.test.ts src/components/ProjectStorage/projectDeviceBindings.test.ts src/components/ProjectStorage/projectLegacyMigration.test.ts src/components/ProjectStorage/projectSqliteRepository.test.ts src/components/ProjectStorage/projectLocalSqliteRepository.test.ts src/components/ProjectStorage/projectLocalObjectStorage.test.ts src/components/ProjectStorage/projectAssetManager.test.ts src/components/ProjectStorage/projectAssetCacheStorage.test.ts src/components/ProjectStorage/projectMigrationService.test.ts src/components/ProjectStorage/projectRemoteRepositoryProxy.test.ts src/components/ProjectStorage/projectStoryboardPlayback.test.ts src/components/ProjectStorage/projectAssetCollectionService.test.ts src/components/ProjectStorage/projectWorkspaceBootstrap.test.ts src/components/ProjectStorage/projectRemoteProfiles.test.ts src/components/ProjectStorage/projectRemoteDatabase.test.ts src/components/ProjectStorage/projectKodoStorage.test.ts src/components/ProjectStorage/projectRemoteRepository.test.ts src/components/ImageProcessingWorkspace/imageProcessingModel.test.ts src/components/ImageProcessingWorkspace/imageProcessingPipeline.test.ts src/components/ImageProcessingWorkspace/imageUpscaleModel.test.ts src/components/MultiFrameSpriteWorkspace/model.test.ts src/components/VoiceDeploymentWorkspace/voiceDeploymentModel.test.ts src/components/VoiceDeploymentWorkspace/voicePersonalSpaceCollector.test.ts src/components/PersonalSpaceWorkspace/personalSpaceProjectSessionActions.test.ts src/components/PersonalSpaceWorkspace/projectManagementActions.test.ts src/components/PersonalSpaceWorkspace/currentProjectSpacePersistence.test.ts src/components/PersonalSpaceWorkspace/projectRemoteDeviceBinding.test.ts src/components/PersonalSpaceWorkspace/projectRemoteProfileActions.test.ts src/components/PersonalSpaceWorkspace/projectRemoteProfileDraftModel.test.ts src/components/PersonalSpaceWorkspace/projectRemoteSyncQueue.test.ts src/components/PersonalSpaceWorkspace/projectSpaceState.test.ts src/components/PersonalSpaceWorkspace/projectWorkspaceStartup.test.ts src/components/PersonalSpaceWorkspace/remoteProjectMessages.test.ts src/components/PersonalSpaceWorkspace/useSelectedProjectRemoteProfileBinding.test.ts src/components/PersonalSpaceWorkspace/personalSpaceModel.test.ts src/components/PersonalSpaceWorkspace/storyboardVoiceDrag.test.ts src/components/PersonalSpaceWorkspace/personalSpaceUploadModel.test.ts src/components/PersonalSpaceWorkspace/personalSpaceFileStorage.test.ts src/components/PersonalSpaceWorkspace/projectAssetResourceResolver.test.ts src/components/PersonalSpaceWorkspace/projectManagementDirtyModel.test.ts src/components/PersonalSpaceWorkspace/projectManagementModel.test.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@vitejs/plugin-react": "^5.1.1",
    "antd": "^6.0.0",
    "electron-updater": "^6.8.9",
    "jszip": "^3.10.1",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "qiniu": "^7.15.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "build": {
    "appId": "com.linjiawen.game-design-tools",
    "productName": "Game Design Tools",
    "directories": {
      "output": "../game-design-tools-windows-x64"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jiawen-afk",
        "repo": "game-design-tools",
        "releaseType": "release",
        "vPrefixedTagName": true
      }
    ],
    "files": [
      "dist/**",
      "electron/**",
      "scripts/**",
      "package.json"
    ],
    "asarUnpack": [
      "scripts/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    },
    "artifactName": "${productName}-${version}-${arch}-${os}.${ext}"
  }
}
